<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quên Mật Khẩu"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="30dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/edtEmailQuenMK"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập Email đã đăng ký"
            android:inputType="textEmailAddress"
            android:padding="15dp"
            android:background="@android:drawable/edit_text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnGuiOTP"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Gửi mã OTP"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FF5722"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:id="@+id/layoutReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhập mã xác thực đã gửi về Email:"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/edtOTP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã OTP (6 số)"
            android:inputType="number"
            android:maxLength="6"
            android:padding="15dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/edtPassMoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mật khẩu mới"
            android:inputType="textPassword"
            android:padding="15dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnXacNhanDoiMK"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Xác nhận đổi mật khẩu"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>