<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginHorizontal="12dp"
    android:addStatesFromChildren="true"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="false"
        android:focusable="false"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            >

            <TextView
                android:id="@+id/tvMaDonHang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đơn hàng #123"
                android:textColor="@color/black"
                android:clickable="false"
                android:focusable="false"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrangThai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_status_orange"
                android:paddingHorizontal="8dp"
                android:clickable="false"
                android:focusable="false"
                android:paddingVertical="2dp"
                android:text="Chờ xác nhận"
                android:textColor="#FF9800"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvNgayMua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:layout_marginTop="2dp"
            android:text="2026-02-10 23:07:25"
            android:textColor="#757575"
            android:textSize="12sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:id="@+id/scrollImages"
            android:scrollbars="none"
            android:clickable="false"
            android:focusable="false"
            android:duplicateParentState="true"
            >

            <LinearLayout
                android:id="@+id/layoutImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="false"
                android:focusable="false"
                android:duplicateParentState="true"
                >
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:clickable="false"
            android:focusable="false"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#EEEEEE" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSoLuongDH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                android:text="Tổng 1 sản phẩm"
                android:textColor="#757575"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:clickable="false"
                android:focusable="false"
                android:text="Thành tiền: "
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvGiaDH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="67.500.000đ"
                android:clickable="false"
                android:focusable="false"
                android:textColor="#F44336"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>