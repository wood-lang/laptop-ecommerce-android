<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"> <View
    android:id="@+id/headerBackground"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:background="#2196F3" /> <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbarCTDH"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="@android:color/transparent"
    app:titleTextColor="#FFFFFF" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTimeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbarCTDH"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layoutTrangThai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiến trình đơn hàng"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgStep1"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_check_circle_gray" />

                <View
                    android:id="@+id/line1"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />

                <ImageView
                    android:id="@+id/imgStep2"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_check_circle_gray" />

                <View
                    android:id="@+id/line2"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />

                <ImageView
                    android:id="@+id/imgStep3"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_check_circle_gray" />

                <View
                    android:id="@+id/line3"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />

                <ImageView
                    android:id="@+id/imgStep4"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_check_circle_gray" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:text="Chờ duyệt"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Đóng gói"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingEnd="15dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Vận chuyển"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingStart="15dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Hoàn tất"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTrangThaiHuy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_dialog_rounded"
                android:backgroundTint="#FFEBEE"
                android:gravity="center"
                android:padding="12dp"
                android:text="⚠️ ĐƠN HÀNG ĐÃ BỊ HỦY"
                android:textColor="#D32F2F"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvChiTietDonHang"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBottomBar"
        android:layout_below="@id/cardTimeline"
        android:clipToPadding="false"
        android:padding="16dp" />

    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHuyDonHang"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="HỦY ĐƠN HÀNG"
            android:textColor="#D32F2F"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="#EF9A9A"
            app:strokeWidth="1.5dp"
            android:visibility="gone" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDaNhanHang"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="8dp"
            android:text="ĐÃ NHẬN ĐƯỢC HÀNG"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            android:visibility="gone" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMuaLai"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="MUA LẠI ĐƠN NÀY"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#2196F3"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            android:visibility="gone" />
    </LinearLayout>

</RelativeLayout>